// This is your Prisma schema file,

// learn more about it in the docs: https://pris.ly/d/prisma-schema



generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "sqlite"

  url      = env("DATABASE_URL")

}



model User {

  id        String   @id @default(uuid()) @map("_id")

  email     String   @unique

  password  String

  name      String

  avatar    String?

  bio       String?

  verified  Boolean  @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt



  // Relations

  posts     Post[]

  chats     ChatParticipant[]

  messages  Message[]

  contacts  Contact[] @relation("UserContacts")

  meetings        MeetingParticipant[]

  organizedMeetings Meeting[]

  sentRequests    Contact[] @relation("ContactRequests")



  @@map("users")

}



model Chat {

  id        String   @id @default(uuid()) @map("_id")

  name      String?

  type      String   @default("DIRECT")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt



  // Relations

  participants ChatParticipant[]

  messages     Message[]



  @@map("chats")

}



model ChatParticipant {

  id     String @id @default(uuid()) @map("_id")

  userId String

  chatId String

  role   String          @default("MEMBER")

  joinedAt DateTime @default(now())



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)



  @@unique([userId, chatId])

  @@map("chat_participants")

}



model Message {

  id        String   @id @default(uuid()) @map("_id")

  content   String

  type      String      @default("TEXT")

  chatId    String

  senderId  String

  createdAt DateTime @default(now())



  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)



  @@map("messages")

}



model Contact {

  id        String   @id @default(uuid()) @map("_id")

  userId    String

  contactId String

  status    String        @default("PENDING")

  createdAt DateTime @default(now())



  user    User @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)

  contact User @relation("ContactRequests", fields: [contactId], references: [id], onDelete: Cascade)



  @@unique([userId, contactId])

  @@map("contacts")

}



model Meeting {

  id          String   @id @default(uuid()) @map("_id")

  title       String

  description String?

  startTime   DateTime

  endTime     DateTime

  organizerId String

  roomId      String?

  status      String        @default("SCHEDULED")

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt



  organizer User @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  participants MeetingParticipant[]



  @@map("meetings")

}



model MeetingParticipant {

  id        String @id @default(uuid()) @map("_id")

  meetingId String

  userId    String

  status    String              @default("PENDING")

  joinedAt  DateTime?



  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([meetingId, userId])

  @@map("meeting_participants")

}



model Post {

  id        String   @id @default(uuid()) @map("_id")

  content   String

  mediaUrl  String?

  mediaType String?

  userId    String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@map("posts")

}



